---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import T from '../components/T.astro';
import { t } from '../i18n';
import type { ToolKey } from '../lib/tools';

interface Props {
  /** EN-only <head> metadata. */
  title: string;
  description: string;
  /** Which tool's wording to pull from the i18n dictionaries. */
  toolKey: ToolKey;
}

const { title, description, toolKey } = Astro.props;
const tool = t[toolKey];
---

<Layout title={title} description={description}>
  <div class="parchment-page">
    <Nav breadcrumb={tool.breadcrumb} breadcrumbHref="/toolbox/" />

    <main class="main">
      <h1 class="page-title"><T t={tool.title} /></h1>
      <p class="page-blurb"><T t={tool.blurb} /></p>

      <slot />

      <p class="disclaimer"><T t={tool.disclaimer} /></p>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .main {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    padding: 24px clamp(20px, 4vw, 44px) 64px;
    width: 100%;
    flex: 1;
  }
</style>
