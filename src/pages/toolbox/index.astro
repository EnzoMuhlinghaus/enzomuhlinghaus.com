---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const tools = [
  {
    href: '/toolbox/pace-calculator/',
    dot: 'var(--accent)',
    nameEn: 'Pace Calculator',
    nameFr: "Calculateur d'Allure",
    descEn: 'Splits & race pace.',
    descFr: 'Allures et temps de passage.',
  },
  {
    href: '/toolbox/mas-vo2max/',
    dot: '#4a6a52',
    nameEn: 'MAS / VO2max',
    nameFr: 'VMA / VO2max',
    descEn: 'Measure the engine.',
    descFr: 'Mesurer le moteur.',
  },
  {
    href: '/toolbox/race-predictor/',
    dot: '#5d7a8c',
    nameEn: 'Race Predictor',
    nameFr: 'Prédicteur de Course',
    descEn: '5K → marathon times.',
    descFr: 'Du 5 km au marathon.',
  },
  {
    href: '/toolbox/strava-namer/',
    dot: '#a2843c',
    nameEn: 'Strava Namer',
    nameFr: 'Nommeur Strava',
    descEn: 'Names & descriptions.',
    descFr: 'Titres et descriptions.',
  },
];
---

<Layout
  title="The Toolbox — Enzo Muhlinghaus"
  description="Small running tools built for my own training: pace calculator, MAS/VO2max estimator, race predictor, Strava namer."
>
  <div class="parchment-page">
    <Nav breadcrumbEn="TOOLBOX" breadcrumbFr="BOÎTE À OUTILS" />

    <main class="main">
      <h1 class="page-title">
        <span class="i18n-en">The Toolbox</span>
        <span class="i18n-fr">La Boîte à Outils</span>
      </h1>
      <p class="page-blurb">
        <span class="i18n-en">Small tools built for my own training, shared here.</span>
        <span class="i18n-fr">De petits outils construits pour mon entraînement, partagés ici.</span>
      </p>

      <div class="tool-grid">
        {
          tools.map((t) => (
            <a href={t.href} class="tool-card">
              <div class="dot" style={`background:${t.dot}`} />
              <span>
                <strong>
                  <span class="i18n-en">{t.nameEn}</span>
                  <span class="i18n-fr">{t.nameFr}</span>
                </strong>
                <span class="tool-desc">
                  <span class="i18n-en">{t.descEn}</span>
                  <span class="i18n-fr">{t.descFr}</span>
                </span>
              </span>
            </a>
          ))
        }
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .main {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    padding: 24px clamp(20px, 4vw, 44px) 64px;
    width: 100%;
    flex: 1;
  }

  .page-blurb {
    margin-bottom: 40px;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .tool-card {
    background: var(--cream);
    border: 1.5px solid var(--ink);
    border-radius: 14px;
    padding: 26px;
    display: flex;
    flex-direction: column;
    gap: 34px;
    transition: transform 0.15s ease;
    box-shadow: 0 2px 8px rgba(66, 40, 14, 0.18);
  }

  .tool-card:hover {
    transform: translateY(-4px) rotate(-0.4deg);
  }

  .tool-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .dot {
    width: 13px;
    height: 13px;
    transform: rotate(45deg);
  }

  .tool-card strong {
    display: block;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 24px;
    margin-bottom: 8px;
  }

  .tool-desc {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-70);
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .tool-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
